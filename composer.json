{
	"config": {
		"platform-check": false,
		"allow-plugins": {
			"php-http/discovery": true
		}
	},
	"repositories": [
		{
			"name": "j4mie/idiorm",
			"type": "vcs",
			"url": "https://github.com/tt-rss/tt-rss-idiorm.git"
		},
		{
			"type": "package",
			"package": {
				"name": "mervick/material-design-icons",
				"version": "4.0.1",
				"dist": {
					"url": "https://github.com/mervick/material-design-icons/archive/fef8017b22997a103a51ea4412029b9100e665db.zip",
					"type": "zip"
				},
				"source": {
					"url": "https://github.com/mervick/material-design-icons.git",
					"type": "git",
					"reference": "fef8017b22997a103a51ea4412029b9100e665db"
				}
			}
		}
	],
	"autoload": {
		"psr-4": {
			"": "classes/"
		},
		"files": [
			"include/functions.php"
		]
	},
	"require": {
		"spomky-labs/otphp": "^11.3",
		"chillerlan/php-qrcode": "^5.0.5",
		"mervick/material-design-icons": "4.0.1",
		"j4mie/idiorm": "dev-master",
		"soundasleep/html2text": "^2.1",
		"guzzlehttp/guzzle": "^7.0",
		"dragonmantank/cron-expression": "^3.4"
	}
}
